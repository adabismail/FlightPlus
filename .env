# ─── Django ──────────────────────────────────────
DJANGO_SECRET_KEY=your-super-secret-key-at-least-50-chars-long
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ────────────────────────────────────
DB_NAME=flightpulse_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db          # Use 'localhost' for local dev (no Docker)
DB_PORT=5432

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0    # Use redis://localhost:6379/0 for local dev

# ─── Amadeus API ─────────────────────────────────
# Sign up at: https://developers.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret
AMADEUS_HOSTNAME=test             # Use 'test' for sandbox, 'production' for live

# ─── Email / SMTP ────────────────────────────────
# For Gmail: enable 2FA and create an App Password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your.email@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password_16chars
DEFAULT_FROM_EMAIL=FlightPulse <your.email@gmail.com>

# ─── Twilio (SMS) ────────────────────────────────
# Sign up at: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX   # Your Twilio phone number